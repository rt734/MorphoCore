        { "name": "transition", "durationSeconds": 2.5, "fps": 30 },
        { "name": "hold", "durationSeconds": 3.0, "fps": 30 }
      ],
      "muscles": ["quadriceps", "glutes", "shoulders", "core"],
      "difficulty": "beginner",
      "tags": ["standing", "strength"],
      "cameraPreset": "front",
      "prerequisites": ["yoga.mountain-pose"],
      "commonMistakes": [
