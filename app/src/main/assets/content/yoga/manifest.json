      "muscles": ["quadriceps", "glutes", "shoulders"],
      "difficulty": "beginner",
      "tags": ["standing", "strength"],
      "cameraPreset": "side",
      "prerequisites": ["yoga.warrior-1"],
      "commonMistakes": [
        { "description": "Leaning the torso forward over the front leg rather than keeping it stacked directly over the hips." },
        { "description": "Allowing the back foot to angle inward too much, which reduces hip opening and stability." }
      ]
    },
    {
      "id": "yoga.downward-dog",
