      "tags": ["squat", "compound", "legs"],
      "cameraPreset": "side",
      "prerequisites": [],
      "commonMistakes": [
        { "description": "Allowing the knees to track inward (valgus collapse) during the ascent, placing high shear stress on the ACL and medial collateral ligament." },
        { "description": "Performing a butt-wink by allowing the pelvis to posteriorly tilt at the bottom of the squat, which flexes the lumbar spine under load and increases disc injury risk." }
      ]
    },
