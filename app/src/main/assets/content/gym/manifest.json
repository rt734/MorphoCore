      "muscles": ["hamstrings", "glutes", "back", "core"],
      "difficulty": "advanced",
      "tags": ["deadlift", "compound", "posterior-chain"],
      "cameraPreset": "side",
      "prerequisites": ["gym.squat"],
      "commonMistakes": [
        { "description": "Jerking the bar off the floor instead of building tension gradually, causing the lower back to round before the legs can engage." },
        { "description": "Allowing the bar to drift away from the body during the pull, increasing the moment arm on the lumbar spine and dramatically raising injury risk." }
