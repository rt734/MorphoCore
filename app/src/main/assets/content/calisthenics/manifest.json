      "commonMistakes": [
        {
          "description": "Neglecting to use a false grip (wrapping the wrists over the bar) on ring or bar muscle-ups, making the transition phase nearly impossible because the wrist cannot rotate around the bar efficiently at the top of the pull."
        },
        {
          "description": "Losing tension during the transition phase between pull and push by allowing the elbows to flare wide, which causes the chest to collide with the bar instead of clearing it and stalls forward momentum."
        }
      ]
    },
