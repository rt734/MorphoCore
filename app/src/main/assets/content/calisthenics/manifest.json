      "cameraPreset": "front",
      "prerequisites": [],
      "commonMistakes": [
        {
          "description": "Failing to initiate the pull with scapular depression and retraction, leading to a shoulder-dominant pull that bypasses the lats entirely."
        },
        {
          "description": "Not reaching full elbow extension at the bottom of each rep, shortening the effective range of motion and reducing the stretch stimulus on the lats."
        }
      ]
    },
    {
