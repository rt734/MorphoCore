      "cameraPreset": "side",
      "prerequisites": [],
      "commonMistakes": [
        {
          "description": "Allowing the hips to sag toward the floor because the core is not engaged, placing compressive load on the lumbar spine throughout the movement."
        },
        {
          "description": "Positioning the hands too far forward of the shoulders, which shifts load onto the anterior deltoids and away from the pectorals while overstressing the wrists."
        }
      ]
    },
    {
      "id": "calisthenics.pull-up",
